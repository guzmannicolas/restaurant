---
import Layout from '../layouts/Layout.astro';

const menu = [
  { nombre: 'Classic Smash', desc: 'Doble medallón, queso cheddar, pickles y salsa secreta', precio: '$4.500', img: '/images/menu/classic-smash.jpg' },
  { nombre: 'BBQ Bacon', desc: 'Cheddar ahumado, bacon crocante, cebolla caramelizada y BBQ', precio: '$5.200', img: '/images/menu/bbq-bacon.jpg' },
  { nombre: 'Crispy Chicken', desc: 'Pollo crocante, coleslaw, jalapeños y mayo picante', precio: '$4.800', img: '/images/menu/crispy-chicken.jpg' },
  { nombre: 'Veggie Deluxe', desc: 'Medallón de lentejas, aguacate, rúcula y queso brie', precio: '$4.200', img: '/images/menu/veggie-deluxe.jpg' },
  { nombre: 'The Monster', desc: 'Triple medallón, triple cheddar, bacon y huevo frito', precio: '$6.800', img: '/images/menu/the-monster.jpg' },
  { nombre: 'Truffle Shroom', desc: 'Medallón wagyu, hongos salteados, aioli de trufa y rúcula', precio: '$7.500', img: '/images/menu/truffle-shroom.jpg' },
];

const testimonios = [
  { nombre: 'Martina G.', texto: 'La mejor hamburguesa que probé en mi vida. El Classic Smash es una obra de arte.', estrellas: 5 },
  { nombre: 'Lucas R.', texto: 'El BBQ Bacon me cambió la vida. Vengo todos los fines de semana.', estrellas: 5 },
  { nombre: 'Sofía M.', texto: 'Increíble calidad y atención. El ambiente es genial. 100% recomendado.', estrellas: 5 },
];

const galeria = [
  { img: '/images/galeria/interior.jpg', alt: 'Interior del local' },
  { img: '/images/galeria/cocina.jpg', alt: 'La cocina' },
  { img: '/images/galeria/hamburguesas.jpg', alt: 'Hamburguesas' },
  { img: '/images/galeria/equipo.jpg', alt: 'Nuestro equipo' },
  { img: '/images/galeria/barra.jpg', alt: 'La barra' },
  { img: '/images/galeria/ambiente.jpg', alt: 'Ambiente del local' },
];
---

<Layout title="Burger & Co. — Hamburguesas Artesanales">
  <!-- NAV -->
  <nav class="fixed top-0 w-full z-40 bg-[#2C1810]/95 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <span class="font-bebas text-2xl text-[#FF6B35] tracking-wider">Burger & Co.</span>
      <div class="hidden md:flex gap-8 text-[#FFF8F0] text-sm font-medium">
        <a href="#menu" class="hover:text-[#FF6B35] transition-colors">Menú</a>
        <a href="#nosotros" class="hover:text-[#FF6B35] transition-colors">Nosotros</a>
        <a href="#galeria" class="hover:text-[#FF6B35] transition-colors">Galería</a>
        <a href="#contacto" class="hover:text-[#FF6B35] transition-colors">Contacto</a>
      </div>
      <a href="#menu" class="bg-[#FF6B35] text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-[#e55a25] transition-colors">Ver Menú</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex items-center justify-center text-center px-4 relative overflow-hidden">
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover z-0" src="/videos/hero.mp4"></video>
    <div class="absolute inset-0 bg-[#2C1810]/70 z-10"></div>
    <div class="relative z-20 reveal">
      <p class="text-[#D4A574] text-sm font-semibold uppercase tracking-[0.3em] mb-4">Desde 2018 · Buenos Aires</p>
      <h1 class="font-bebas text-7xl md:text-9xl text-[#FFF8F0] leading-none tracking-wide mb-4">Burger<br/><span class="text-[#FF6B35]">&amp; Co.</span></h1>
      <p class="text-[#FFF8F0]/70 text-xl md:text-2xl max-w-lg mx-auto mb-10">Hamburguesas artesanales con ingredientes frescos. Sin apuros. Sin compromiso.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#menu" class="bg-[#FF6B35] text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-[#e55a25] transition-all hover:scale-105">Ver el Menú</a>
        <a href="#nosotros" class="border border-[#FFF8F0]/30 text-[#FFF8F0] px-8 py-4 rounded-full font-semibold text-lg hover:border-[#FF6B35] hover:text-[#FF6B35] transition-all">Nuestra Historia</a>
      </div>
    </div>
  </section>

  <!-- MENÚ -->
  <section id="menu" class="py-24 px-4 bg-[#FFF8F0]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-[#FF6B35] text-sm font-semibold uppercase tracking-widest mb-2">Lo que hacemos</p>
        <h2 class="font-bebas text-5xl md:text-6xl text-[#2C1810]">Nuestro Menú</h2>
        <div class="w-12 h-1 bg-[#FF6B35] mx-auto mt-4 rounded-full"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {menu.map((item, i) => (
          <div class="reveal reveal-up bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow group" style={`--delay: ${i * 80}ms`}>
            <div class="overflow-hidden">
              <img src={item.img} alt={item.nombre} class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="font-bebas text-2xl text-[#2C1810] mb-1">{item.nombre}</h3>
              <p class="text-[#1A1A1A]/60 text-sm leading-relaxed mb-4">{item.desc}</p>
              <span class="text-[#FF6B35] font-bold text-xl">{item.precio}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOBRE NOSOTROS -->
  <section id="nosotros" class="py-24 px-4 bg-[#2C1810]">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div class="reveal reveal-left">
        <img src="/images/nosotros/historia.jpg" alt="Nuestra historia" class="rounded-2xl w-full shadow-2xl" />
      </div>
      <div class="reveal reveal-right text-[#FFF8F0]">
        <p class="text-[#D4A574] text-sm font-semibold uppercase tracking-widest mb-3">Nuestra historia</p>
        <h2 class="font-bebas text-5xl md:text-6xl leading-tight mb-6">Nació de una <span class="text-[#FF6B35]">pasión</span></h2>
        <p class="text-[#FFF8F0]/70 leading-relaxed mb-4">Todo empezó en 2018 cuando Marcos, cocinero autodidacta, decidió que Buenos Aires merecía una hamburguesa de verdad. Sin congelados, sin atajos.</p>
        <p class="text-[#FFF8F0]/70 leading-relaxed mb-8">Hoy somos un equipo de 12 personas que comparte la misma obsesión: cada hamburguesa tiene que ser la mejor que probaste en tu vida.</p>
        <div class="flex gap-8">
          <div>
            <p class="font-bebas text-4xl text-[#FF6B35]">+15K</p>
            <p class="text-[#FFF8F0]/50 text-sm">Burgers servidas</p>
          </div>
          <div>
            <p class="font-bebas text-4xl text-[#FF6B35]">4.9★</p>
            <p class="text-[#FFF8F0]/50 text-sm">Puntuación media</p>
          </div>
          <div>
            <p class="font-bebas text-4xl text-[#FF6B35]">6 años</p>
            <p class="text-[#FFF8F0]/50 text-sm">En el barrio</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GALERÍA -->
  <section id="galeria" class="py-24 px-4 bg-[#FFF8F0]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-[#FF6B35] text-sm font-semibold uppercase tracking-widest mb-2">En imágenes</p>
        <h2 class="font-bebas text-5xl md:text-6xl text-[#2C1810]">El Local</h2>
        <div class="w-12 h-1 bg-[#FF6B35] mx-auto mt-4 rounded-full"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {galeria.map((item, i) => (
          <div class="reveal reveal-up overflow-hidden rounded-2xl aspect-[4/3] group" style={`--delay: ${i * 60}ms`}>
            <img src={item.img} alt={item.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="py-24 px-4 bg-[#1A1A1A]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-[#FF6B35] text-sm font-semibold uppercase tracking-widest mb-2">Lo que dicen</p>
        <h2 class="font-bebas text-5xl md:text-6xl text-[#FFF8F0]">Nuestros Clientes</h2>
        <div class="w-12 h-1 bg-[#FF6B35] mx-auto mt-4 rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {testimonios.map((t, i) => (
          <div class="reveal reveal-up bg-[#2C1810] rounded-2xl p-8" style={`--delay: ${i * 100}ms`}>
            <p class="text-[#FF6B35] text-xl mb-4">{'★'.repeat(t.estrellas)}</p>
            <p class="text-[#FFF8F0]/80 leading-relaxed mb-6 italic">"{t.texto}"</p>
            <p class="text-[#D4A574] font-semibold">— {t.nombre}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contacto" class="py-24 px-4 bg-[#FFF8F0]">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-[#FF6B35] text-sm font-semibold uppercase tracking-widest mb-2">Encontranos</p>
        <h2 class="font-bebas text-5xl md:text-6xl text-[#2C1810]">Contacto</h2>
        <div class="w-12 h-1 bg-[#FF6B35] mx-auto mt-4 rounded-full"></div>
      </div>
      <div class="reveal reveal-up bg-white rounded-2xl shadow-lg p-8 md:p-12">
        <div class="grid md:grid-cols-2 gap-8 mb-10">
          <div>
            <p class="text-[#FF6B35] font-semibold text-sm uppercase tracking-widest mb-1">Dirección</p>
            <p class="text-[#2C1810]">Av. Corrientes 1234, CABA</p>
          </div>
          <div>
            <p class="text-[#FF6B35] font-semibold text-sm uppercase tracking-widest mb-1">Horarios</p>
            <p class="text-[#2C1810]">Lun–Vie 12:00–23:00<br/>Sáb–Dom 12:00–00:00</p>
          </div>
        </div>
        <form class="space-y-4">
          <div class="grid md:grid-cols-2 gap-4">
            <input type="text" placeholder="Tu nombre" class="w-full px-4 py-3 rounded-xl border border-[#D4A574]/30 bg-[#FFF8F0] focus:outline-none focus:border-[#FF6B35] transition-colors" />
            <input type="email" placeholder="Tu email" class="w-full px-4 py-3 rounded-xl border border-[#D4A574]/30 bg-[#FFF8F0] focus:outline-none focus:border-[#FF6B35] transition-colors" />
          </div>
          <textarea rows="4" placeholder="Tu mensaje" class="w-full px-4 py-3 rounded-xl border border-[#D4A574]/30 bg-[#FFF8F0] focus:outline-none focus:border-[#FF6B35] transition-colors resize-none"></textarea>
          <button type="submit" class="w-full bg-[#FF6B35] text-white py-4 rounded-xl font-semibold text-lg hover:bg-[#e55a25] transition-all hover:scale-[1.02]">Enviar Mensaje</button>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#2C1810] text-[#FFF8F0]/50 text-center py-8 px-4">
    <p class="font-bebas text-2xl text-[#FF6B35] mb-2">Burger & Co.</p>
    <p class="text-sm">© 2024 Burger & Co. — Sitio desarrollado por <a href="#" class="text-[#FF6B35] hover:underline">Zepe Dev</a></p>
  </footer>
</Layout>

<style>
  .font-bebas { font-family: 'Bebas Neue', cursive; }
  .font-inter { font-family: 'Inter', sans-serif; }

  .reveal { opacity: 0; transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal-left { transform: translateX(-30px); }
  .reveal-right { transform: translateX(30px); }
  .reveal-up { transform: translateY(24px); }
  .reveal.visible { opacity: 1; transform: translate(0,0); }
  .reveal.visible .reveal-up {
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay, 0ms);
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  function initReveal() {
    const obs = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.reveal').forEach(el => { el.classList.remove('visible'); obs.observe(el); });
  }
  initReveal();
  document.addEventListener('astro:page-load', initReveal);
</script>
